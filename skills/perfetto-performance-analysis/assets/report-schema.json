{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Gracker/Perfetto-Skills/schemas/report-v2.json",
  "title": "Perfetto Skills evidence report v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trace", "findings", "evidence", "limitations"],
  "properties": {
    "schema_version": {"const": 2},
    "trace": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["side", "sha256"],
        "properties": {
          "side": {"type": "string"},
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "start_ns": {"type": "integer"},
          "end_ns": {"type": "integer"}
        }
      }
    },
    "workflow": {"type": "string"},
    "status": {"enum": ["complete", "partial", "unavailable"]},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "claim_class", "evidence", "alternatives", "limitations"],
        "properties": {
          "claim": {"type": "string", "minLength": 1},
          "claim_class": {"enum": ["observation", "correlation", "mechanism", "causal", "root_cause"]},
          "mechanism": {"type": "string"},
          "falsifier": {"type": "string"},
          "alternatives": {"type": "array", "items": {"type": "string"}},
          "limitations": {"type": "array", "items": {"type": "string"}},
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["evidence_id", "row", "column", "expected"],
              "properties": {
                "evidence_id": {"type": "string"},
                "row": {"type": "integer", "minimum": 0},
                "column": {"type": "string"},
                "expected": {}
              }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "trace", "status", "validation", "processor", "rows", "identity"],
        "properties": {
          "evidence_id": {"type": "string"},
          "trace": {
            "type": "object",
            "required": ["sha256", "side"],
            "properties": {
              "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "side": {"type": "string"}
            }
          },
          "status": {"enum": ["observed", "empty", "missing_evidence", "not_applicable", "skipped_condition", "error"]},
          "validation": {"type": "object"},
          "processor": {
            "type": "object",
            "required": ["status", "binary_sha256"],
            "properties": {
              "status": {"enum": ["verified", "unsupported"]},
              "binary_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "version": {"type": "string"},
              "platform": {"type": "string"},
              "issues": {"type": "array", "items": {"type": "string"}}
            }
          },
          "identity": {"type": "object"},
          "rows": {"type": "array"}
        }
      }
    },
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
