{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Gracker/Perfetto-Skills/schemas/report-v1.json",
  "title": "Perfetto Skills evidence report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workflow", "status", "trace", "findings", "evidence", "limitations"],
  "properties": {
    "schema_version": {"const": 1},
    "workflow": {"type": "string", "minLength": 1},
    "status": {"enum": ["complete", "partial", "unavailable"]},
    "trace": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["side", "path", "sha256"],
        "properties": {
          "side": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "start_ns": {"type": "integer"},
          "end_ns": {"type": "integer"}
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "claim", "confidence", "evidence_refs"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "claim": {"type": "string", "minLength": 1},
          "confidence": {"enum": ["high", "medium", "low"]},
          "evidence_refs": {"type": "array", "items": {"type": "string"}},
          "recommendation": {"type": "string"}
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "trace_side", "source", "summary"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "trace_side": {"type": "string", "minLength": 1},
          "source": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "process": {"type": "string"},
          "thread": {"type": "string"},
          "start_ns": {"type": "integer"},
          "duration_ns": {"type": "integer"},
          "artifact": {"type": "string"}
        }
      }
    },
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}

