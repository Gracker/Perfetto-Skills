{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Gracker/Perfetto-Skills/schemas/comparison-input-v1.json",
  "title": "Perfetto Skills comparison side",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trace", "metrics", "limitations"],
  "properties": {
    "schema_version": {"const": 1},
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "start_ns": {"type": "integer"},
        "end_ns": {"type": "integer"}
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "unit", "definition", "evidence_refs"],
        "properties": {
          "status": {"enum": ["observed", "not_observed", "missing_evidence", "out_of_scope"]},
          "value": {"type": "number"},
          "unit": {"type": "string", "minLength": 1},
          "definition": {"type": "string", "minLength": 1},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}
