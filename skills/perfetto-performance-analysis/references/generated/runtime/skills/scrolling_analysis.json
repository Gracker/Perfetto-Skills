{
  "android": {
    "adapters": [
      {
        "id": "official_frame_timeline_or_legacy",
        "selection": "actual rows first; legacy Choreographer/DrawFrame fallback",
        "source": "perfetto stdlib android/frames/timeline.sql",
        "version_hint": {
          "frame_timeline_min_api": 31
        }
      },
      {
        "id": "android_input_source",
        "selection": "data-source descriptor, build type, config, then rows",
        "version_hint": {
          "proto_input_min_api_hint": 34
        }
      },
      {
        "id": "kernel_tracepoints",
        "selection": "available events, trace config/setup errors, schema, then rows"
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "${package}*",
      "*.raster",
      "*.ui",
      "*CodecLooper*",
      "*Compile*",
      "*Fence*",
      "*InputConsumer*",
      "*MediaCodec*",
      "*NuPlayer*",
      "*QueuedWork*",
      "*RV Prefetch*",
      "*RecyclerView*Prefetch*",
      "*SQLiteDatabase*",
      "*Shader*",
      "*SharedPreferences*",
      "*VideoDecoder*",
      "*commit*SharedPref*",
      "*compile*",
      "*deliverInputEvent*",
      "*dequeueBuffer*",
      "*dispatchTouchEvent*",
      "*eglSwapBuffers*",
      "*fence*",
      "*fsync*",
      "*getSharedPreferences*",
      "*onInterceptTouchEvent*",
      "*onOutputBufferAvailable*",
      "*onTouchEvent*",
      "*openFile*",
      "*processInputEventForCompatibility*",
      "*queueVideoBuffer*",
      "*shader*",
      "*sqlite*",
      "*waitToFinish*",
      "Choreographer#doFrame%",
      "DrawFrame%",
      "Framework::BeginFrame%",
      "PlayerLoop%",
      "RenderThread",
      "VSYNC-sf",
      "[0-9]*",
      "[0-9]*.raster",
      "[0-9]*.ui",
      "actual_frame_timeline_slice",
      "cpufreq"
    ]
  },
  "id": "scrolling_analysis",
  "identity": {
    "aliases": [
      "package",
      "process_name"
    ],
    "policy": "verify_if_present",
    "rewriteTo": "recommended_process_name_param",
    "scope": "process"
  },
  "inputs": [
    {
      "description": "应用包名（可选，不填则分析所有应用）",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "分析起始时间戳（纳秒，可选）",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳（纳秒，可选）",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "是否执行逐帧详情分析（L4，默认不执行）",
      "name": "enable_frame_details",
      "required": false,
      "type": "boolean"
    },
    {
      "description": "每个滑动区间最多返回的掉帧帧数（默认 200，配合 batch_frame_root_cause 批量分类）",
      "name": "max_frames_per_session",
      "required": false,
      "type": "number"
    },
    {
      "default": true,
      "description": "是否启用专家探针（帧方差等）",
      "name": "enable_expert_probes",
      "required": false,
      "type": "boolean"
    },
    {
      "default": 5,
      "description": "触发帧方差探针的最小掉帧数",
      "name": "frame_variance_probe_min_janky_frames",
      "required": false,
      "type": "number"
    },
    {
      "default": 8,
      "description": "帧间高抖动阈值（ms）",
      "name": "frame_variance_transition_threshold_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 0.5,
      "description": "输入处理慢判定阈值：占当前 VSync 帧预算的比例（默认 50%）",
      "name": "input_handling_budget_ratio",
      "required": false,
      "type": "number"
    },
    {
      "default": 3,
      "description": "同帧输入事件堆积候选阈值（默认 3，必须同时有处理耗时证据才作为根因）",
      "name": "input_event_backlog_threshold",
      "required": false,
      "type": "number"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.input",
      "android.frames.timeline",
      "android.binder",
      "android.garbage_collection",
      "android.monitor_contention"
    ],
    "required_tables": []
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "e656c756ddaf23a13c7cffdced2f87f75aa07e49",
    "path": "backend/skills/composite/scrolling_analysis.skill.yaml",
    "sha256": "db12ba810a107ad991b5f42de2764e08b2d6f86b5f11d57cfb0c50b62773a126"
  },
  "steps": [
    {
      "id": "init_cpu_topology",
      "name": "初始化 CPU 拓扑",
      "optional": true,
      "skill": "cpu_topology_view",
      "type": "skill"
    },
    {
      "id": "frame_timeline_check",
      "name": "FrameTimeline 数据源检测",
      "query_id": "scrolling_analysis/frame_timeline_check",
      "result_dependencies": [],
      "save_as": "frame_timeline",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1",
      "id": "vsync_config",
      "name": "Vsync 配置",
      "query_id": "scrolling_analysis/vsync_config",
      "result_dependencies": [],
      "save_as": "environment",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && environment.data[0]?.has_data === 1",
      "id": "performance_summary",
      "name": "帧性能汇总",
      "query_id": "scrolling_analysis/performance_summary",
      "result_dependencies": [],
      "save_as": "perf_summary",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && environment.data[0]?.has_data === 1",
      "id": "input_data_fallback_view",
      "name": "Input 数据源回退视图",
      "optional": true,
      "query_id": "scrolling_analysis/input_data_fallback_view",
      "result_dependencies": [],
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && environment.data[0]?.has_data === 1",
      "id": "input_data_check",
      "name": "Input 数据源检测",
      "optional": true,
      "query_id": "scrolling_analysis/input_data_check",
      "result_dependencies": [],
      "save_as": "input_data",
      "type": "atomic"
    },
    {
      "condition": "input_data.data[0]?.total_input_events > 0",
      "id": "input_latency_summary",
      "name": "Input 延迟概览",
      "optional": true,
      "query_id": "scrolling_analysis/input_latency_summary",
      "result_dependencies": [],
      "save_as": "input_latency",
      "type": "atomic"
    },
    {
      "condition": "${enable_expert_probes|true} == true && frame_timeline.data[0]?.has_frame_timeline === 1 && environment.data[0]?.has_data === 1",
      "id": "expert_analysis_window",
      "name": "专家分析窗口",
      "optional": true,
      "query_id": "scrolling_analysis/expert_analysis_window",
      "result_dependencies": [],
      "save_as": "expert_window",
      "type": "atomic"
    },
    {
      "condition": "${enable_expert_probes|true} == true && frame_timeline.data[0]?.has_frame_timeline === 1 && (perf_summary?.data?.[0]?.janky_frames || 0) >= (frame_variance_probe_min_janky_frames || 5)",
      "id": "frame_variance_probe",
      "name": "帧方差探针",
      "optional": true,
      "params": {
        "end_ts": "${expert_window.data?.[0]?.window_end_ts ?? end_ts ?? null}",
        "package": "${package}",
        "start_ts": "${expert_window.data?.[0]?.window_start_ts ?? start_ts ?? null}",
        "transition_threshold_ms": "${frame_variance_transition_threshold_ms|8}"
      },
      "save_as": "frame_variance_probe",
      "skill": "frame_pipeline_variance",
      "type": "skill"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && environment.data[0]?.has_data === 1",
      "id": "jank_type_stats",
      "name": "掉帧类型统计",
      "query_id": "scrolling_analysis/jank_type_stats",
      "result_dependencies": [],
      "save_as": "jank_stats",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && environment.data[0]?.has_data === 1",
      "id": "scroll_sessions",
      "name": "滑动区间列表",
      "query_id": "scrolling_analysis/scroll_sessions",
      "result_dependencies": [],
      "save_as": "sessions",
      "type": "atomic"
    },
    {
      "condition": "scroll_sessions.data?.length > 0",
      "id": "session_stats_batch",
      "name": "滑动区间统计（批量）",
      "optional": true,
      "query_id": "scrolling_analysis/session_stats_batch",
      "result_dependencies": [],
      "save_as": "session_stats",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && environment.data[0]?.has_data === 1",
      "id": "session_jank",
      "name": "区间掉帧统计",
      "optional": true,
      "query_id": "scrolling_analysis/session_jank",
      "result_dependencies": [],
      "save_as": "session_jank_data",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && environment?.data?.[0]?.has_data === 1 && ((perf_summary?.data?.[0]?.janky_frames || 0) > 0 || (jank_stats?.data?.[0]?.real_jank_count || 0) > 0)",
      "id": "get_app_jank_frames",
      "name": "获取真正掉帧帧",
      "query_id": "scrolling_analysis/get_app_jank_frames",
      "result_dependencies": [],
      "save_as": "app_jank_frames",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && environment?.data?.[0]?.has_data === 1 && ((perf_summary?.data?.[0]?.janky_frames || 0) > 0 || (jank_stats?.data?.[0]?.real_jank_count || 0) > 0)",
      "id": "batch_frame_root_cause",
      "name": "掉帧列表（含根因分类）",
      "optional": true,
      "query_id": "scrolling_analysis/batch_frame_root_cause",
      "result_dependencies": [],
      "save_as": "batch_root_cause",
      "type": "atomic"
    },
    {
      "id": "global_context_flags",
      "name": "全局上下文标志",
      "optional": true,
      "query_id": "scrolling_analysis/global_context_flags",
      "result_dependencies": [],
      "save_as": "global_context",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && (perf_summary?.data?.[0]?.total_frames || 0) > 0",
      "id": "session_quadrant_summary",
      "name": "滑动过程四象限分布",
      "optional": true,
      "query_id": "scrolling_analysis/session_quadrant_summary",
      "result_dependencies": [],
      "save_as": "session_quadrant",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && (perf_summary?.data?.[0]?.total_frames || 0) > 0",
      "id": "session_cpu_freq",
      "name": "滑动过程 CPU 频率",
      "optional": true,
      "query_id": "scrolling_analysis/session_cpu_freq",
      "result_dependencies": [],
      "save_as": "session_freq",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && (perf_summary?.data?.[0]?.total_frames || 0) > 0",
      "id": "session_thread_core_affinity",
      "name": "关键线程大小核分布",
      "optional": true,
      "query_id": "scrolling_analysis/session_thread_core_affinity",
      "result_dependencies": [],
      "save_as": "session_core_affinity",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 1 && (perf_summary?.data?.[0]?.total_frames || 0) > 0 && enable_frame_details === true",
      "id": "root_cause_classification",
      "name": "根因分类",
      "optional": true,
      "query_id": "scrolling_analysis/root_cause_classification",
      "result_dependencies": [],
      "save_as": "conclusion",
      "type": "atomic"
    },
    {
      "condition": "frame_timeline.data[0]?.has_frame_timeline === 0",
      "id": "fallback_no_frame_timeline",
      "name": "数据源不可用提示",
      "query_id": "scrolling_analysis/fallback_no_frame_timeline",
      "result_dependencies": [],
      "save_as": "fallback_info",
      "type": "atomic"
    }
  ],
  "type": "composite",
  "version": "2.1",
  "workflow": "scrolling"
}
