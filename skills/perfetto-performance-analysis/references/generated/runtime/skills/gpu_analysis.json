{
  "android": {
    "adapters": [
      {
        "id": "official_frame_timeline_or_legacy",
        "selection": "actual rows first; legacy Choreographer/DrawFrame fallback",
        "source": "perfetto stdlib android/frames/timeline.sql",
        "version_hint": {
          "frame_timeline_min_api": 31
        }
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "${package}*",
      "actual_frame_timeline_slice",
      "android_gpu_frequency",
      "android_gpu_memory_per_process"
    ]
  },
  "id": "gpu_analysis",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "应用包名（可选，不填则分析全局 GPU 状态）",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "分析起始时间戳（纳秒，可选）",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳（纳秒，可选）",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "default": 70,
      "description": "GPU 高负载判定阈值（最高频占比百分比）",
      "name": "high_freq_threshold_pct",
      "required": false,
      "type": "number"
    },
    {
      "default": 40,
      "description": "GPU 中负载判定阈值（最高频占比百分比）",
      "name": "mid_freq_threshold_pct",
      "required": false,
      "type": "number"
    },
    {
      "default": 10,
      "description": "GPU 低负载判定阈值（最高频占比百分比）",
      "name": "low_freq_threshold_pct",
      "required": false,
      "type": "number"
    },
    {
      "default": 0.7,
      "description": "频率突降检测比例（低于上次频率的该比例视为突降）",
      "name": "freq_drop_ratio",
      "required": false,
      "type": "number"
    },
    {
      "default": 20,
      "description": "频率突降次数阈值（超过该值判定为限频）",
      "name": "freq_drop_count_threshold",
      "required": false,
      "type": "number"
    },
    {
      "default": 500000000,
      "description": "高负载时段最小持续时间阈值（纳秒，默认500ms）",
      "name": "high_load_min_dur_ns",
      "required": false,
      "type": "number"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.gpu.frequency",
      "android.gpu.memory"
    ],
    "required_tables": []
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "ff5d4a00696318f7bfc5868fb54c84b38c32b880",
    "path": "backend/skills/composite/gpu_analysis.skill.yaml",
    "sha256": "c99bd1159e7f337b0d5dd490100f66e9134271d55a7bbf0362ebf64d3a1d9602"
  },
  "steps": [
    {
      "id": "data_check",
      "name": "GPU 数据源检测",
      "query_id": "gpu_analysis/data_check",
      "result_dependencies": [],
      "save_as": "data_check",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_gpu_data === 1",
      "id": "gpu_freq_overview",
      "name": "GPU 频率概览",
      "optional": true,
      "query_id": "gpu_analysis/gpu_freq_overview",
      "result_dependencies": [],
      "save_as": "gpu_freq_overview",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_gpu_memory === 1",
      "id": "gpu_memory_overview",
      "name": "GPU 内存概览",
      "optional": true,
      "query_id": "gpu_analysis/gpu_memory_overview",
      "result_dependencies": [],
      "save_as": "gpu_memory_overview",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_gpu_data === 1",
      "id": "gpu_freq_distribution",
      "name": "GPU 频率档位分布",
      "optional": true,
      "query_id": "gpu_analysis/gpu_freq_distribution",
      "result_dependencies": [],
      "save_as": "gpu_freq_distribution",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_gpu_data === 1 && data_check.data[0]?.has_frame_timeline === 1",
      "id": "gpu_frame_correlation",
      "name": "GPU-帧渲染关联",
      "optional": true,
      "query_id": "gpu_analysis/gpu_frame_correlation",
      "result_dependencies": [],
      "save_as": "gpu_frame_correlation",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_gpu_data === 1",
      "id": "gpu_high_load_periods",
      "name": "GPU 高负载时段",
      "optional": true,
      "query_id": "gpu_analysis/gpu_high_load_periods",
      "result_dependencies": [],
      "save_as": "gpu_high_load",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_gpu_data === 1",
      "id": "root_cause_classification",
      "name": "GPU 根因分类",
      "optional": true,
      "query_id": "gpu_analysis/root_cause_classification",
      "result_dependencies": [],
      "save_as": "conclusion",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_gpu_data === 0",
      "id": "fallback_no_gpu_data",
      "name": "GPU 数据不可用",
      "query_id": "gpu_analysis/fallback_no_gpu_data",
      "result_dependencies": [],
      "save_as": "fallback_info",
      "type": "atomic"
    }
  ],
  "type": "composite",
  "version": "3.0",
  "workflow": "gpu-rendering"
}
