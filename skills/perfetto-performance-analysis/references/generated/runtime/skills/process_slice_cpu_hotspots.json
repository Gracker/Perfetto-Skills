      "name": "thread_scope",
      "required": false,
      "type": "string"
    },
    {
      "description": "分析起始时间戳(ns)，默认 trace_start()",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳(ns)，默认 trace_end()",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "default": 0,
      "description": "聚合后最小 CPU 时间阈值(ns)",
      "name": "min_cpu_ns",
      "required": false,
      "type": "integer"
    },
    {
      "default": 10,
      "description": "返回 TopK 条目",
      "name": "top_k",
      "required": false,
      "type": "integer"
    }
  ],
