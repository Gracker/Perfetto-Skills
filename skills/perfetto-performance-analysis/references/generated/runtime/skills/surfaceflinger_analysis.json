{
  "android": {
    "adapters": [
      {
        "id": "official_frame_timeline_or_legacy",
        "selection": "actual rows first; legacy Choreographer/DrawFrame fallback",
        "source": "perfetto stdlib android/frames/timeline.sql",
        "version_hint": {
          "frame_timeline_min_api": 31
        }
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "*Client*",
      "*Commit*",
      "*Composite*",
      "*Fence*",
      "*GLES*",
      "*GPU completion*",
      "*GPU*",
      "*HWC*",
      "*Latch*",
      "*Layer*",
      "*Present*",
      "*Waiting for GPU*",
      "*commit*",
      "*composite*",
      "*fence*",
      "*gpu*",
      "*hwc*",
      "*latchBuffer*",
      "*onMessageInvalidate*",
      "*onMessageRefresh*",
      "*postComposition*",
      "*present*",
      "*updateTexImage*",
      "/system/bin/surfaceflinger",
      "VSYNC-sf",
      "surfaceflinger"
    ]
  },
  "id": "surfaceflinger_analysis",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "应用包名（可选，用于关联应用与 SF 交互）",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "分析起始时间戳（纳秒，可选）",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳（纳秒，可选）",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "default": 1.5,
      "description": "慢合成判定倍数（超过 VSync 周期的该倍数视为慢合成）",
      "name": "slow_composition_multiplier",
      "required": false,
      "type": "number"
    },
    {
      "default": 12,
      "description": "合成评级-较差阈值（平均合成耗时 ms）",
      "name": "composition_rating_poor_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 8,
      "description": "合成评级-一般阈值（平均合成耗时 ms）",
      "name": "composition_rating_fair_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 4,
      "description": "合成评级-良好阈值（平均合成耗时 ms）",
      "name": "composition_rating_good_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 10,
      "description": "长 Fence 等待阈值（ms）",
      "name": "long_fence_threshold_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 16,
      "description": "Fence 严重程度-critical 阈值（ms）",
      "name": "fence_critical_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 8,
      "description": "Fence 严重程度-warning 阈值（ms）",
      "name": "fence_warning_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 10,
      "description": "慢合成占比阈值（百分比，超过则判定为合成延迟）",
      "name": "slow_pct_threshold",
      "required": false,
      "type": "number"
    },
    {
      "default": 0.5,
      "description": "GPU 合成比例阈值（超过该比例判定为 GPU 合成负载高）",
      "name": "gpu_comp_ratio_threshold",
      "required": false,
      "type": "number"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.frames.timeline"
    ],
    "required_tables": []
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "cda248e2324a554220e15f8ce5ede39f2f53468d",
    "path": "backend/skills/composite/surfaceflinger_analysis.skill.yaml",
    "sha256": "883c9e637f8166269939f7f817af9ef900c89e2215ca90cb3c0ad0d45443daad"
  },
  "steps": [
    {
      "id": "data_check",
      "name": "SurfaceFlinger 数据检测",
      "query_id": "surfaceflinger_analysis/data_check",
      "result_dependencies": [],
      "save_as": "data_check",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_sf_process === 1",
      "id": "vsync_config",
      "name": "VSync 配置",
      "query_id": "surfaceflinger_analysis/vsync_config",
      "result_dependencies": [],
      "save_as": "vsync_env",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_composition_data === 1",
      "id": "composition_overview",
      "name": "合成概览",
      "query_id": "surfaceflinger_analysis/composition_overview",
      "result_dependencies": [
        "vsync_env"
      ],
      "save_as": "composition_overview",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_composition_data === 1",
      "id": "gpu_hwc_stats",
      "name": "GPU/HWC 合成统计",
      "optional": true,
      "query_id": "surfaceflinger_analysis/gpu_hwc_stats",
      "result_dependencies": [],
      "save_as": "gpu_hwc_stats",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_composition_data === 1",
      "id": "slow_compositions",
      "name": "慢合成列表",
      "query_id": "surfaceflinger_analysis/slow_compositions",
      "result_dependencies": [
        "vsync_env"
      ],
      "save_as": "slow_compositions",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_sf_process === 1",
      "id": "fence_analysis",
      "name": "Fence 等待分析",
      "optional": true,
      "query_id": "surfaceflinger_analysis/fence_analysis",
      "result_dependencies": [],
      "save_as": "fence_analysis",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_composition_data === 1",
      "id": "composition_phases",
      "name": "合成阶段分布",
      "optional": true,
      "query_id": "surfaceflinger_analysis/composition_phases",
      "result_dependencies": [],
      "save_as": "composition_phases",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_sf_process === 1",
      "id": "layer_stats",
      "name": "Layer 统计",
      "optional": true,
      "query_id": "surfaceflinger_analysis/layer_stats",
      "result_dependencies": [],
      "save_as": "layer_stats",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_composition_data === 1",
      "id": "root_cause_classification",
      "name": "SF 根因分类",
      "query_id": "surfaceflinger_analysis/root_cause_classification",
      "result_dependencies": [
        "vsync_env"
      ],
      "save_as": "conclusion",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_sf_process === 0",
      "id": "fallback_no_sf_data",
      "name": "SF 数据不可用",
      "query_id": "surfaceflinger_analysis/fallback_no_sf_data",
      "result_dependencies": [],
      "save_as": "fallback_info",
      "type": "atomic"
    }
  ],
  "type": "composite",
  "version": "3.0",
  "workflow": "gpu-rendering"
}
