  "id": "lock_binder_wait",
  "identity": {
    "aliases": [
      "process_name",
      "package"
    ],
    "policy": "required",
    "rewriteTo": "recommended_process_name_param",
    "scope": "process"
  },
  "inputs": [
    {
      "description": "目标进程名",
      "name": "process_name",
      "required": true,
      "type": "string"
    },
    {
      "description": "分析起始时间戳(ns)",
      "name": "start_ts",
      "required": true,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳(ns)",
      "name": "end_ts",
      "required": true,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.binder",
      "android.monitor_contention",
      "slices.with_context"
    ],
    "required_tables": [
      "thread_state",
      "thread",
      "process"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "a5cefea76e5dfa550683414ffe23ec3a65a46bfb",
