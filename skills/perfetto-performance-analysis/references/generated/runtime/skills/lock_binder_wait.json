    "sha256": "6f37cd847c361b12b95f9490498ee8a48e810631a2f8f708934ee961343ed9d5"
  },
  "steps": [
    {
      "id": "main_thread_blocking_chain",
      "name": "主线程阻塞链",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "process_name": "${process_name}",
        "start_ts": "${start_ts}"
