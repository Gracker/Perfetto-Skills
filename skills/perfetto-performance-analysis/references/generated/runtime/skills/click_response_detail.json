{
  "android": {
    "adapters": [
      {
        "id": "android_input_source",
        "selection": "data-source descriptor, build type, config, then rows",
        "version_hint": {
          "proto_input_min_api_hint": 34
        }
      },
      {
        "id": "kernel_tracepoints",
        "selection": "available events, trace config/setup errors, schema, then rows"
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "${process_name}*",
      "*InputDispatcher*",
      "*InputEvent*",
      "*InputReader*",
      "*deliverInput*",
      "*dispatchMotion*",
      "/system/bin/%",
      "aq:pending:deliver*",
      "cpufreq",
      "deliverInputEvent src=*",
      "system_server"
    ]
  },
  "id": "click_response_detail",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "事件开始时间戳(ns)",
      "name": "event_ts",
      "required": true,
      "type": "timestamp"
    },
    {
      "description": "事件结束时间戳(ns)",
      "name": "event_end_ts",
      "required": true,
      "type": "timestamp"
    },
    {
      "description": "dispatch-to-ACK 总延迟(ms)",
      "name": "total_ms",
      "required": true,
      "type": "number"
    },
    {
      "description": "分发延迟(ms)",
      "name": "dispatch_ms",
      "required": false,
      "type": "number"
    },
    {
      "description": "处理延迟(ms)",
      "name": "handling_ms",
      "required": false,
      "type": "number"
    },
    {
      "description": "事件类型",
      "name": "event_type",
      "required": false,
      "type": "string"
    },
    {
      "description": "事件动作",
      "name": "event_action",
      "required": false,
      "type": "string"
    },
    {
      "description": "进程名",
      "name": "process_name",
      "required": true,
      "type": "string"
    },
    {
      "description": "Perfetto 跳转开始时间",
      "name": "perfetto_start",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "Perfetto 跳转结束时间",
      "name": "perfetto_end",
      "required": false,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.input",
      "android.binder",
      "linux.cpu.frequency"
    ],
    "required_tables": [
      "thread",
      "process",
      "thread_state",
      "sched_slice"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "a5cefea76e5dfa550683414ffe23ec3a65a46bfb",
    "path": "backend/skills/composite/click_response_detail.skill.yaml",
    "sha256": "3bf411e6c0f6db9de2434fb0ad420cb0a0140388c5968306f5ad569b3ff0c3e7"
  },
  "steps": [
    {
      "id": "init_cpu_topology",
      "name": "初始化 CPU 拓扑",
      "optional": true,
      "skill": "cpu_topology_view",
      "type": "skill"
    },
    {
      "id": "event_info",
      "name": "事件基本信息",
      "query_id": "click_response_detail/event_info",
      "result_dependencies": [],
      "save_as": "event_basic",
      "type": "atomic"
    },
    {
      "id": "input_dispatch_breakdown",
      "name": "输入分发管线分解",
      "optional": true,
      "query_id": "click_response_detail/input_dispatch_breakdown",
      "result_dependencies": [],
      "type": "atomic"
    },
    {
      "id": "input_pipeline_lifecycle",
      "name": "输入管线生命周期",
      "optional": true,
      "query_id": "click_response_detail/input_pipeline_lifecycle",
      "result_dependencies": [],
      "save_as": "input_lifecycle",
      "type": "atomic"
    },
    {
      "id": "cpu_core_analysis",
      "name": "大小核占比分析",
      "query_id": "click_response_detail/cpu_core_analysis",
      "result_dependencies": [],
      "save_as": "cpu_core",
      "type": "atomic"
    },
    {
      "id": "quadrant_analysis",
      "name": "四大象限分析",
      "optional": true,
      "query_id": "click_response_detail/quadrant_analysis",
      "result_dependencies": [],
      "save_as": "quadrant",
      "type": "atomic"
    },
    {
      "id": "blocking_analysis",
      "name": "阻塞原因分析",
      "params": {
        "end_ts": "${event_end_ts}",
        "package": "${process_name}",
        "start_ts": "${event_ts}",
        "top_k": 5
      },
      "save_as": "blocking",
      "skill": "main_thread_states_in_range",
      "type": "skill"
    },
    {
      "id": "binder_analysis",
      "name": "Binder 调用分析",
      "params": {
        "end_ts": "${event_end_ts}",
        "package": "${process_name}",
        "start_ts": "${event_ts}"
      },
      "save_as": "binder_calls",
      "skill": "binder_in_range",
      "type": "skill"
    },
    {
      "id": "main_thread_sync_binder",
      "name": "主线程同步 Binder",
      "params": {
        "end_ts": "${event_end_ts}",
        "package": "${process_name}",
        "start_ts": "${event_ts}"
      },
      "save_as": "main_sync_binder",
      "skill": "binder_blocking_in_range",
      "type": "skill"
    },
    {
      "id": "sched_latency",
      "name": "调度延迟分析",
      "params": {
        "end_ts": "${event_end_ts}",
        "package": "${process_name}",
        "start_ts": "${event_ts}"
      },
      "save_as": "sched_delay",
      "skill": "main_thread_sched_latency_in_range",
      "type": "skill"
    },
    {
      "id": "main_thread_file_io",
      "name": "主线程文件 IO",
      "params": {
        "end_ts": "${event_end_ts}",
        "min_dur_ns": 500000,
        "package": "${process_name}",
        "start_ts": "${event_ts}",
        "top_k": 10
      },
      "save_as": "main_file_io",
      "skill": "main_thread_file_io_in_range",
      "type": "skill"
    },
    {
      "id": "click_diagnosis",
      "inputs": [
        "event_basic",
        "cpu_core",
        "quadrant",
        "blocking",
        "binder_calls",
        "main_sync_binder",
        "sched_delay",
        "main_file_io"
      ],
      "name": "慢点击诊断",
      "rules": [
        {
          "condition": "quadrant.data[0]?.q3_runnable_ms > 20 && (sched_delay.data[0]?.severe_count || 0) > 0",
          "confidence": "high",
          "diagnosis": "主线程 Runnable 等待 ${quadrant.data[0].q3_runnable_ms}ms，且存在 ${sched_delay.data[0].severe_count} 次 >8ms 调度延迟",
          "severity": "warning",
          "suggestions": [
            "CPU 资源争抢，检查后台线程负载",
            "减少并发任务"
          ]
        },
        {
          "condition": "quadrant.data[0]?.sleeping_pct > 50 && ((main_file_io.data[0]?.percent || 0) > 2 || ((main_sync_binder?.data?.find(r => r.is_main_blocked === 1)?.total_block_ms) || 0) > 15)",
          "confidence": "medium",
          "diagnosis": "主线程 Sleeping 占比 ${quadrant.data[0].sleeping_pct}% 且存在 IO/Binder 阻塞证据",
          "severity": "warning",
          "suggestions": [
            "检查主线程阻塞原因",
            "将阻塞操作移到后台线程"
          ]
        },
        {
          "condition": "cpu_core.data[0]?.big_core_pct < 20 && cpu_core.data[0]?.total_running_ms > 20 && quadrant.data[0]?.q3_runnable_ms > 20 && (sched_delay.data[0]?.severe_count || 0) > 0 && !(cpu_core.data[0]?.classify_method || '').includes('cpu_id_fallback')",
          "confidence": "medium",
          "diagnosis": "主线程大核占比偏低（${cpu_core.data[0].big_core_pct}%）且 Runnable 等待 ${quadrant.data[0].q3_runnable_ms}ms，存在调度供给不足迹象",
          "severity": "warning",
          "suggestions": [
            "检查是否有高优先级线程长期占用大核",
            "减少点击关键路径中的并发争抢"
          ]
        },
        {
          "condition": "(cpu_core.data[0]?.classify_method || '').includes('cpu_id_fallback')",
          "confidence": "medium",
          "diagnosis": "核类型判定回退到 CPU 编号阈值，大小核相关结论置信度有限",
          "severity": "info",
          "suggestions": [
            "补充或检查 cpu_frequency/cpu capacity 数据后再判断大小核调度问题"
          ]
        },
        {
          "condition": "(main_file_io.data[0]?.total_ms > 20 || main_file_io.data[0]?.percent > 5) && (quadrant.data[0]?.sleeping_pct || 0) > 20",
          "confidence": "high",
          "diagnosis": "主线程文件 IO '${main_file_io.data[0].io_slice}' 耗时 ${main_file_io.data[0].total_ms}ms（占比 ${main_file_io.data[0].percent}%）",
          "severity": "warning",
          "suggestions": [
            "避免在点击关键路径执行同步文件读写",
            "将数据库/文件访问改为异步或延后"
          ]
        },
        {
          "condition": "binder_calls.data[0]?.total_client_ms > 30 && ((main_sync_binder?.data?.find(r => r.is_main_blocked === 1)?.total_block_ms) || 0) > 10",
          "confidence": "high",
          "diagnosis": "Binder 调用 ${binder_calls.data[0].server_process} 耗时 ${binder_calls.data[0].total_client_ms}ms，且主线程同步 Binder 阻塞明显",
          "severity": "warning",
          "suggestions": [
            "将 Binder 调用移到后台线程",
            "使用异步 Binder"
          ]
        }
      ],
      "type": "diagnostic"
    }
  ],
  "type": "composite",
  "version": "2.0",
  "workflow": "interaction"
}
