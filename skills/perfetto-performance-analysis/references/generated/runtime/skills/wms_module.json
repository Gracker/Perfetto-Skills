      "*relayoutWindow*",
      "*setVisibility*",
      "*startActivity*",
      "*startingWindow*",
      "*windowFocus*",
      "system_server"
    ]
  },
  "id": "wms_module",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "Target package name",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "Target timestamp",
      "name": "ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "Analysis start timestamp",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "Analysis end timestamp",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [],
    "required_tables": [
      "slice",
      "thread",
      "process"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "1e23eb4369431c88f9847dcec69ccb81946bdb26",
    "path": "backend/skills/modules/framework/wms_module.skill.yaml",
    "sha256": "ec088f394851b6fb0426109a0105b0d0ae930adf759b15011ab45a18a1a5831f"
  },
  "steps": [
    {
      "id": "window_animation_overview",
      "name": "窗口动画概览",
      "query_id": "wms_module/window_animation_overview",
      "result_dependencies": [],
      "save_as": "animation_overview",
      "type": "atomic"
    },
    {
      "id": "activity_transitions",
      "name": "Activity 转场分析",
      "query_id": "wms_module/activity_transitions",
      "result_dependencies": [],
      "save_as": "transitions",
      "type": "atomic"
    },
    {
      "id": "window_state_changes",
      "name": "窗口状态变化",
      "query_id": "wms_module/window_state_changes",
      "result_dependencies": [],
      "save_as": "state_changes",
      "type": "atomic"
    },
    {
      "id": "slow_animations",
      "name": "慢动画检测",
      "query_id": "wms_module/slow_animations",
      "result_dependencies": [],
      "save_as": "slow_animations",
      "type": "atomic"
    },
    {
      "id": "window_draw_latency",
      "name": "窗口绘制延迟",
      "query_id": "wms_module/window_draw_latency",
      "result_dependencies": [],
      "save_as": "draw_latency",
      "type": "atomic"
    },
    {
      "id": "wms_diagnosis",
      "inputs": [
        "animation_overview",
        "transitions",
        "slow_animations",
        "draw_latency"
      ],
      "name": "WMS 诊断",
      "rules": [
        {
          "condition": "slow_animations.data.length > 0",
          "confidence": "high",
          "diagnosis": "检测到 ${slow_animations.data.length} 个慢窗口动画，最长 ${slow_animations.data[0]?.dur_ms}ms",
          "evidence_fields": [
            "slow_animations.data.length",
            "slow_animations.data[0]?.dur_ms",
            "slow_animations.data[0]?.animation_type"
          ],
          "suggestions": [
            "检查动画期间是否有主线程阻塞",
            "检查 GPU 渲染负载",
            "考虑简化动画效果"
          ]
        },
        {
          "condition": "transitions.data.filter(t => t.quality === 'very_slow').length > 3",
          "confidence": "high",
          "diagnosis": "多个 Activity 转场过慢 (>500ms)",
          "evidence_fields": [
            "transitions.data[0]?.dur_ms",
            "transitions.data[0]?.transition_type"
          ],
          "suggestions": [
            "检查 Activity 生命周期中的耗时操作",
            "优化首帧渲染性能"
          ]
        },
        {
          "condition": "animation_overview.data[0]?.max_dur_ms > 500",
          "confidence": "medium",
          "diagnosis": "窗口动画最大耗时 ${animation_overview.data[0]?.max_dur_ms}ms，超过 500ms 阈值",
          "evidence_fields": [
            "animation_overview.data[0]?.animation_type",
            "animation_overview.data[0]?.max_dur_ms"
          ],
          "suggestions": [
            "分析具体动画场景",
            "检查系统负载情况"
          ]
        },
        {
          "condition": "draw_latency.data[0]?.avg_dur_ms > 16",
          "confidence": "medium",
          "diagnosis": "应用窗口绘制平均耗时 ${draw_latency.data[0]?.avg_dur_ms}ms，超过 16ms 帧时间",
          "evidence_fields": [
            "draw_latency.data[0]?.draw_event",
            "draw_latency.data[0]?.avg_dur_ms"
          ],
          "suggestions": [
            "优化 onDraw 实现",
            "减少过度绘制",
            "使用硬件加速"
          ]
        }
      ],
      "type": "diagnostic"
    }
  ],
  "type": "composite",
  "version": "1.0",
  "workflow": "interaction"
}
