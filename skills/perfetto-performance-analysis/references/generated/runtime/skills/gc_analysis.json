{
  "android": {
    "adapters": [
      {
        "id": "official_frame_timeline_or_legacy",
        "selection": "actual rows first; legacy Choreographer/DrawFrame fallback",
        "source": "perfetto stdlib android/frames/timeline.sql",
        "version_hint": {
          "frame_timeline_min_api": 31
        }
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "*${package}*"
    ]
  },
  "id": "gc_analysis",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "目标应用包名（支持 GLOB），留空分析所有 GC 事件",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "default": 5,
      "description": "最小 GC 时长阈值 (毫秒)",
      "name": "min_gc_dur_ms",
      "required": false,
      "type": "number"
    },
    {
      "description": "分析起始时间戳（纳秒，可选）",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳（纳秒，可选）",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.garbage_collection"
    ],
    "required_tables": [
      "slice"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "cda248e2324a554220e15f8ce5ede39f2f53468d",
    "path": "backend/skills/composite/gc_analysis.skill.yaml",
    "sha256": "9953952ad063229e1a5f04d58a41962bce74d74d1c303ca177cb7055c0afb366"
  },
  "steps": [
    {
      "id": "data_check",
      "name": "数据检测",
      "optional": true,
      "query_id": "gc_analysis/data_check",
      "result_dependencies": [],
      "save_as": "data_check",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "gc_overview",
      "name": "GC 概览",
      "query_id": "gc_analysis/gc_overview",
      "result_dependencies": [],
      "save_as": "gc_overview",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "gc_time_breakdown",
      "name": "GC 耗时分解",
      "query_id": "gc_analysis/gc_time_breakdown",
      "result_dependencies": [],
      "save_as": "gc_time_breakdown",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_long_gc === 1",
      "id": "long_gc_events",
      "name": "长耗时 GC 事件",
      "query_id": "gc_analysis/long_gc_events",
      "result_dependencies": [],
      "save_as": "long_gc_events",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "gc_frame_impact",
      "name": "GC 对帧的影响",
      "optional": true,
      "query_id": "gc_analysis/gc_frame_impact",
      "result_dependencies": [],
      "save_as": "gc_frame_impact",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_process_stats === 1",
      "id": "process_gc_stats",
      "name": "进程 GC 统计",
      "optional": true,
      "query_id": "gc_analysis/process_gc_stats",
      "result_dependencies": [],
      "save_as": "process_gc_stats",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "gc_frequency",
      "name": "GC 频率分析",
      "query_id": "gc_analysis/gc_frequency",
      "result_dependencies": [],
      "save_as": "gc_frequency",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "root_cause_classification",
      "name": "根因分类",
      "optional": true,
      "query_id": "gc_analysis/root_cause_classification",
      "result_dependencies": [],
      "save_as": "root_cause",
      "type": "atomic"
    }
  ],
  "type": "composite",
  "version": "3.0",
  "workflow": "memory"
}
