{
  "android": {
    "adapters": [
      {
        "branches": [
          "api<=28",
          "api29-32",
          "api>=33"
        ],
        "id": "official_android_startup_tags",
        "source": "perfetto stdlib android/startup/startups.sql"
      },
      {
        "id": "kernel_tracepoints",
        "selection": "available events, trace config/setup errors, schema, then rows"
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "bindApplication",
      "handleRelaunchActivity*",
      "performCreate:*",
      "relaunchActivity*"
    ]
  },
  "id": "startup_analysis",
  "identity": {
    "aliases": [
      "package",
      "process_name"
    ],
    "policy": "verify_if_present",
    "rewriteTo": "recommended_process_name_param",
    "scope": "process"
  },
  "inputs": [
    {
      "description": "应用包名（可选，不填则分析所有启动事件）",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "指定启动事件 ID（可选）",
      "name": "startup_id",
      "required": false,
      "type": "integer"
    },
    {
      "description": "启动类型过滤（cold/warm/hot，可选）",
      "name": "startup_type",
      "required": false,
      "type": "string"
    },
    {
      "description": "启动区间开始时间戳（ns，可选）",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "启动区间结束时间戳（ns，可选）",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析模式：full（默认）或 overview（仅启动事件定位）",
      "name": "analysis_mode",
      "required": false,
      "type": "string"
    },
    {
      "description": "是否执行逐个启动事件详情分析（默认 true）",
      "name": "enable_startup_details",
      "required": false,
      "type": "boolean"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.startup.startups",
      "android.startup.time_to_display",
      "android.startup.startup_breakdowns",
      "android.binder"
    ],
    "required_tables": []
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "4489476e5b45a868fbf4bdbf0f10e466870f59bf",
    "path": "backend/skills/composite/startup_analysis.skill.yaml",
    "sha256": "96b682a4206afafddcfb6e63c60e842921381a674744f413881a609e862ef41b"
  },
  "steps": [
    {
      "id": "get_startups",
      "name": "获取启动事件",
      "on_empty": "未检测到启动事件。请确认 Trace 包含应用启动数据。",
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}"
      },
      "save_as": "startups",
      "skill": "startup_events_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0",
      "id": "startup_quality",
      "name": "启动数据质量门禁",
      "query_id": "startup_analysis/startup_quality",
      "result_dependencies": [],
      "save_as": "startup_quality",
      "type": "atomic"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "startup_breakdown",
      "name": "启动延迟归因",
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}",
        "top_k": 15
      },
      "save_as": "breakdown",
      "skill": "startup_breakdown_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "main_thread_slices",
      "name": "主线程关键操作",
      "params": {
        "end_ts": "${end_ts}",
        "min_dur_ns": 1000000,
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}",
        "top_k": 15
      },
      "save_as": "main_thread_slices",
      "skill": "startup_main_thread_slices_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "main_thread_file_io",
      "name": "主线程文件 IO",
      "params": {
        "end_ts": "${end_ts}",
        "min_dur_ns": 500000,
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}",
        "top_k": 15
      },
      "save_as": "main_thread_file_io",
      "skill": "startup_main_thread_file_io_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "startup_binder",
      "name": "启动期间 Binder 调用",
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}",
        "top_k": 15
      },
      "save_as": "startup_binder",
      "skill": "startup_binder_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "main_thread_sync_binder",
      "name": "主线程同步 Binder 调用",
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}",
        "top_k": 15
      },
      "save_as": "main_sync_binder",
      "skill": "startup_main_thread_sync_binder_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "main_thread_binder_blocking",
      "name": "主线程 Binder 阻塞",
      "params": {
        "end_ts": "${end_ts}",
        "min_dur_ns": 5000000,
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}",
        "top_k": 20
      },
      "save_as": "main_binder_blocking",
      "skill": "startup_main_thread_binder_blocking_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "main_thread_state_during_startup",
      "name": "主线程状态分析",
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}"
      },
      "save_as": "main_thread_states",
      "skill": "startup_main_thread_states_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "class_loading",
      "name": "类加载分析",
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}",
        "top_k": 10
      },
      "save_as": "class_loading",
      "skill": "startup_class_loading_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "gc_during_startup",
      "name": "GC 影响分析",
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}",
        "top_k": 10
      },
      "save_as": "gc_during_startup",
      "skill": "startup_gc_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "sched_latency_during_startup",
      "name": "调度延迟分析",
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}",
        "startup_id": "${startup_id}",
        "startup_type": "${startup_type}"
      },
      "save_as": "sched_latency",
      "skill": "startup_sched_latency_in_range",
      "type": "skill"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0) && ${enable_startup_details|true}",
      "id": "analyze_startups",
      "item_params": {
        "dur_ms": "dur_ms",
        "end_ts": "end_ts",
        "original_type": "original_type",
        "package": "package",
        "perfetto_end": "perfetto_end",
        "perfetto_start": "perfetto_start",
        "start_ts": "start_ts",
        "startup_id": "startup_id",
        "startup_type": "startup_type",
        "ttfd_ms": "ttfd_ms",
        "ttid_ms": "ttid_ms"
      },
      "item_skill": "startup_detail",
      "name": "启动事件详细分析",
      "source": "startups",
      "type": "iterator"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview'",
      "id": "startup_diagnosis",
      "inputs": [
        "startups",
        "startup_quality",
        "breakdown",
        "main_thread_slices",
        "main_thread_file_io",
        "startup_binder",
        "main_sync_binder",
        "main_binder_blocking",
        "main_thread_states",
        "class_loading",
        "gc_during_startup",
        "sched_latency"
      ],
      "name": "启动诊断",
      "rules": [
        {
          "condition": "((startup_quality?.data?.[0]?.blocker_count) || 0) > 0",
          "confidence": "high",
          "diagnosis": "启动数据质量存在阻断问题（${startup_quality?.data?.[0]?.issue_codes || 'unknown'}），深度分析已跳过",
          "severity": "critical",
          "suggestions": [
            "优先核对 dur_ms/start_ts/end_ts 的单位与换算逻辑，统一为 ms 展示",
            "检查 TTID/TTFD 字段来源和单位，确认没有误用 us/ns",
            "修复数据口径后重新执行启动分析"
          ]
        },
        {
          "condition": "(startups?.data?.[0]?.ttid_ms || 0) > (startups?.data?.[0]?.dur_ms || 0) + 50",
          "confidence": "medium",
          "diagnosis": "TTID (${startups?.data?.[0]?.ttid_ms}ms) 超出启动总时长 (${startups?.data?.[0]?.dur_ms}ms)，首帧渲染可能在 Perfetto 认定的启动结束后才完成",
          "severity": "warning",
          "suggestions": [
            "可能原因：Activity.setContentView 后仍有异步加载导致首帧延迟，或 RenderThread/SurfaceFlinger 合成排队",
            "检查启动区间结束后是否有较长的 Choreographer#doFrame 或 DrawFrame",
            "如果 TTID 代表真实首帧时间，优化方向应以 TTID 而非 dur 为目标",
            "建议在 Perfetto UI 中检查 startup 结束时间戳附近的帧渲染情况"
          ]
        },
        {
          "condition": "((startup_quality?.data?.[0]?.warning_count) || 0) > 0 && !((startup_quality?.data?.[0]?.issue_codes || '').includes('R008_TTID_GT_DUR') && (startup_quality?.data?.[0]?.warning_count || 0) === 1)",
          "confidence": "medium",
          "diagnosis": "启动数据存在告警项（${startup_quality?.data?.[0]?.issue_codes || 'none'}），结论需结合原始 Trace 复核",
          "severity": "info",
          "suggestions": [
            "重点复核 TTID/TTFD 与启动总时长关系是否合理",
            "保留本次结论作为线索，不直接作为最终定论"
          ]
        },
        {
          "condition": "(startups?.data?.[0]?.type_reclassified || 0) === 1",
          "confidence": "high",
          "diagnosis": "启动类型已从 ${startups?.data?.[0]?.original_type} 修正为 ${startups?.data?.[0]?.startup_type}。判定依据：bindApplication 存在→cold，仅 performCreate 存在→warm，均不存在→保持原始分类。评级已按修正后类型重新计算。",
          "severity": "info",
          "suggestions": [
            "Perfetto 的 startup_type 来自框架层 atrace 标记，在某些场景下可能误报",
            "bindApplication 是进程新建（冷启动）的可靠信号，performCreate 是 Activity 重建（温启动）的可靠信号"
          ]
        },
        {
          "condition": "((startups?.data?.[0]?.dur_ms) || 0) > 2000 && startups?.data?.[0]?.startup_type === 'cold'",
          "confidence": "high",
          "diagnosis": "冷启动时间过长 (${startups?.data?.[0]?.dur_ms}ms)",
          "severity": "critical",
          "suggestions": [
            "检查 Application.onCreate() 中的初始化逻辑",
            "使用 App Startup 库延迟初始化",
            "将耗时操作移到后台线程"
          ]
        },
        {
          "condition": "((startups?.data?.[0]?.dur_ms) || 0) > 1000 && ((startups?.data?.[0]?.dur_ms) || 0) <= 2000 && startups?.data?.[0]?.startup_type === 'cold'",
          "confidence": "high",
          "diagnosis": "冷启动时间偏长 (${startups?.data?.[0]?.dur_ms}ms)，建议优化",
          "severity": "warning",
          "suggestions": [
            "检查 Application.onCreate() 和 Activity.onCreate() 中的耗时操作",
            "将非关键初始化延迟到首帧之后",
            "使用 Baseline Profile 加速类加载和 JIT"
          ]
        },
        {
          "condition": "((startups?.data?.[0]?.dur_ms) || 0) > 1000 && startups?.data?.[0]?.startup_type === 'warm'",
          "confidence": "high",
          "diagnosis": "温启动时间严重偏长 (${startups?.data?.[0]?.dur_ms}ms)，接近甚至超过正常冷启动水平",
          "severity": "critical",
          "suggestions": [
            "温启动进程已存在，不应有 Application.onCreate 开销",
            "检查 Activity.onCreate() 和 onStart()/onResume() 中是否重复执行初始化",
            "将 View 绑定、数据加载等操作移到后台线程"
          ]
        },
        {
          "condition": "((startups?.data?.[0]?.dur_ms) || 0) > 500 && ((startups?.data?.[0]?.dur_ms) || 0) <= 1000 && startups?.data?.[0]?.startup_type === 'warm'",
          "confidence": "high",
          "diagnosis": "温启动时间偏长 (${startups?.data?.[0]?.dur_ms}ms)，建议优化",
          "severity": "warning",
          "suggestions": [
            "检查 Activity.onCreate()/onResume() 中的耗时操作",
            "使用 ViewStub 延迟加载非首屏视图",
            "减少 Activity 重建时的数据库/网络查询"
          ]
        },
        {
          "condition": "((startups?.data?.[0]?.dur_ms) || 0) > 500 && startups?.data?.[0]?.startup_type === 'hot'",
          "confidence": "high",
          "diagnosis": "热启动时间严重偏长 (${startups?.data?.[0]?.dur_ms}ms)，热启动应在 200ms 内完成",
          "severity": "critical",
          "suggestions": [
            "热启动只需 onResume() → 首帧，检查是否有不必要的数据重载",
            "排查 onResume() 中的同步 Binder 或 IO 阻塞"
          ]
        },
        {
          "condition": "((startups?.data?.[0]?.dur_ms) || 0) > 200 && ((startups?.data?.[0]?.dur_ms) || 0) <= 500 && startups?.data?.[0]?.startup_type === 'hot'",
          "confidence": "high",
          "diagnosis": "热启动时间偏长 (${startups?.data?.[0]?.dur_ms}ms)，建议优化",
          "severity": "warning",
          "suggestions": [
            "检查 onResume() 中是否有不必要的数据刷新或视图重建",
            "减少热启动路径上的同步调用"
          ]
        },
        {
          "condition": "(startup_binder?.data?.length || 0) > 0 && ((startup_binder.data[0]?.percent_of_startup) || 0) > 20 && ((startup_binder.data[0]?.main_thread_calls || 0) > 0) && ((((main_sync_binder?.data?.[0]?.percent_of_startup) || 0) > 5) || (((main_binder_blocking?.data?.[0]?.dur_ms) || 0) > 8) || (((main_thread_states?.data?.find(s => s.state === 'D')?.percent) || 0) > 5) || (((main_thread_states?.data?.find(s => s.state === 'S')?.percent) || 0) > 20))",
          "confidence": "high",
          "diagnosis": "Binder 调用占启动时间 ${startup_binder?.data?.[0]?.percent_of_startup}%（含主线程调用）",
          "severity": "warning",
          "suggestions": [
            "减少启动期间的 IPC 调用",
            "将非必要的服务调用延迟到启动后",
            "使用异步 Binder 调用"
          ]
        },
        {
          "condition": "(main_sync_binder?.data?.length || 0) > 0 && ((main_sync_binder.data[0]?.percent_of_startup) || 0) > 8 && ((((main_binder_blocking?.data?.[0]?.dur_ms) || 0) > 16) || (((main_thread_states?.data?.find(s => s.state === 'D')?.percent) || 0) > 5) || (((main_thread_states?.data?.find(s => s.state === 'S')?.percent) || 0) > 20))",
          "confidence": "high",
          "diagnosis": "主线程同步 Binder 占启动时间 ${main_sync_binder?.data?.[0]?.percent_of_startup}% 且主线程存在阻塞态证据",
          "severity": "warning",
          "suggestions": [
            "优先将同步 Binder 调用迁移到后台线程",
            "首屏前只保留必要 IPC，其余延后到首帧后"
          ]
        },
        {
          "condition": "(main_thread_file_io?.data?.length || 0) > 0 && (((main_thread_file_io.data[0]?.percent_of_startup) || 0) > 5 || ((main_thread_file_io.data[0]?.total_dur_ms) || 0) > 50) && ((((main_thread_states?.data?.find(s => s.state === 'D')?.percent) || 0) > 5) || (((main_thread_states?.data?.find(s => s.state === 'S')?.percent) || 0) > 20))",
          "confidence": "high",
          "diagnosis": "主线程文件 IO 占比较高（${main_thread_file_io?.data?.[0]?.percent_of_startup}%）且主线程阻塞态占比偏高",
          "severity": "warning",
          "suggestions": [
            "将文件读取与数据库初始化前移到预热阶段或改为异步",
            "减少启动阶段小文件随机 IO，合并为批量顺序读取"
          ]
        },
        {
          "condition": "(main_thread_states?.data?.length || 0) > 0 && ((main_thread_states.data.find(s => s.state === 'Running')?.percent) || 0) < 50 && ((((main_thread_states.data.find(s => s.state === 'R')?.percent) || 0) + ((main_thread_states.data.find(s => s.state === 'R+')?.percent) || 0)) > 20 || ((((main_thread_states.data.find(s => s.state === 'D')?.percent) || 0) + ((main_thread_states.data.find(s => s.state === 'S')?.percent) || 0)) > 30) || ((((sched_latency?.data?.find(s => s.state === 'R')?.severe_delays) || 0) + ((sched_latency?.data?.find(s => s.state === 'R+')?.severe_delays) || 0)) > 3))",
          "confidence": "medium",
          "diagnosis": "主线程 Running 比例偏低",
          "severity": "warning",
          "suggestions": [
            "分析阻塞原因：IO 等待、锁竞争、调度延迟",
            "将阻塞操作移到后台线程"
          ]
        },
        {
          "condition": "(gc_during_startup?.data?.length || 0) > 0 && ((gc_during_startup.data.find(g => g.is_main_thread === 1)?.percent_of_startup) || 0) > 3",
          "confidence": "medium",
          "diagnosis": "主线程 GC 占启动时间 ${gc_during_startup?.data?.find(g => g.is_main_thread === 1)?.percent_of_startup}%",
          "severity": "warning",
          "suggestions": [
            "减少启动期间的对象分配",
            "避免在启动时创建大量临时对象"
          ]
        },
        {
          "condition": "(sched_latency?.data?.length || 0) > 0 && ((((sched_latency.data.find(s => s.state === 'R')?.severe_delays) || 0) + ((sched_latency.data.find(s => s.state === 'R+')?.severe_delays) || 0)) > 3) && (((sched_latency.data.find(s => s.state === 'R')?.max_wait_ms) || 0) > 8 || ((sched_latency.data.find(s => s.state === 'R+')?.max_wait_ms) || 0) > 8)",
          "confidence": "medium",
          "diagnosis": "主线程调度延迟偏高（>8ms 严重等待次数 ${(sched_latency?.data?.find(s => s.state === 'R')?.severe_delays || 0) + (sched_latency?.data?.find(s => s.state === 'R+')?.severe_delays || 0)}）",
          "severity": "warning",
          "suggestions": [
            "降低启动阶段后台并发，避免与主线程争抢 CPU",
            "检查系统级负载和高优先级抢占线程"
          ]
        },
        {
          "condition": "(breakdown?.data?.length || 0) > 0 && ((breakdown.data.find(b => b.category === 'ClassLoading')?.percent) || 0) > 15 && (class_loading?.data?.length || 0) > 0 && ((class_loading.data[0]?.percent_of_startup) || 0) > 5",
          "confidence": "medium",
          "diagnosis": "类加载占比较高（breakdown ${breakdown?.data?.find(b => b.category === 'ClassLoading')?.percent}%）",
          "severity": "info",
          "suggestions": [
            "使用 baseline profile 预编译热点类",
            "减少启动时加载的类数量"
          ]
        }
      ],
      "type": "diagnostic"
    },
    {
      "condition": "startups.data.length > 0 && '${analysis_mode|full}' !== 'overview' && ((startup_quality?.data?.[0]?.blocker_count || 0) === 0)",
      "id": "startup_evidence_matrix",
      "name": "启动证据矩阵",
      "query_id": "startup_analysis/startup_evidence_matrix",
      "result_dependencies": [
        "main_binder_blocking",
        "main_sync_binder",
        "main_thread_file_io",
        "main_thread_slices",
        "sched_latency",
        "startup_binder"
      ],
      "save_as": "evidence_matrix",
      "type": "atomic"
    }
  ],
  "type": "composite",
  "version": "1.0",
  "workflow": "startup"
}
