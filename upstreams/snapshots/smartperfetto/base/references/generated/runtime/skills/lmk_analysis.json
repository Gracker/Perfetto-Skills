{
  "android": {
    "adapters": [],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "*${package}*",
      "mem.available",
      "mem.free"
    ]
  },
  "id": "lmk_analysis",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "目标应用包名（支持 GLOB），留空分析所有 LMK 事件",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "OOM adj 阈值，过滤低于此值的进程 (更重要的进程)",
      "name": "oom_adj_threshold",
      "required": false,
      "type": "number"
    },
    {
      "description": "分析起始时间戳（纳秒，可选）",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳（纳秒，可选）",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.memory.lmk",
      "linux.memory.general"
    ],
    "required_tables": [
      "android_lmk_events"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "40048058243cbb91ef11082a06ba1e4d0f7d3c5a",
    "path": "backend/skills/composite/lmk_analysis.skill.yaml",
    "sha256": "32494b794e68cb6976f27938f66c022758ebf4fcc0826baa535203c36b6aaceb"
  },
  "steps": [
    {
      "id": "data_check",
      "name": "数据检测",
      "optional": true,
      "query_id": "lmk_analysis/data_check",
      "result_dependencies": [],
      "save_as": "data_check",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "lmk_overview",
      "name": "LMK 事件概览",
      "query_id": "lmk_analysis/lmk_overview",
      "result_dependencies": [],
      "save_as": "lmk_overview",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "lmk_timeline",
      "name": "LMK 事件时间线",
      "query_id": "lmk_analysis/lmk_timeline",
      "result_dependencies": [],
      "save_as": "lmk_timeline",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_high_priority_kills === 1",
      "id": "high_priority_kills",
      "name": "高优先级进程被杀",
      "query_id": "lmk_analysis/high_priority_kills",
      "result_dependencies": [],
      "save_as": "high_priority_kills",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1 && data_check.data[0]?.has_memory_counters === 1",
      "id": "lmk_memory_context",
      "name": "LMK 时刻内存状态",
      "query_id": "lmk_analysis/lmk_memory_context",
      "result_dependencies": [],
      "save_as": "lmk_memory_context",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "lmk_frequency",
      "name": "LMK 发生频率",
      "query_id": "lmk_analysis/lmk_frequency",
      "result_dependencies": [],
      "save_as": "lmk_frequency",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "process_restart_after_lmk",
      "name": "进程重启分析",
      "query_id": "lmk_analysis/process_restart_after_lmk",
      "result_dependencies": [],
      "save_as": "process_restart_after_lmk",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.has_data === 1",
      "id": "root_cause_classification",
      "name": "根因分类",
      "query_id": "lmk_analysis/root_cause_classification",
      "result_dependencies": [],
      "save_as": "root_cause",
      "type": "atomic"
    }
  ],
  "type": "composite",
  "version": "3.0",
  "workflow": "memory"
}
