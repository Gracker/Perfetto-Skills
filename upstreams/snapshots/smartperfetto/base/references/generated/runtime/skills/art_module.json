{
  "android": {
    "adapters": [],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "%${package}%",
      "%GC%",
      "%JIT%",
      "%collection%",
      "%compile%",
      "%garbage%",
      "main"
    ]
  },
  "id": "art_module",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "Target package name",
      "name": "package",
      "required": true,
      "type": "string"
    },
    {
      "description": "Analysis start timestamp",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "Analysis end timestamp",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [],
    "required_tables": []
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "a5cefea76e5dfa550683414ffe23ec3a65a46bfb",
    "path": "backend/skills/modules/framework/art_module.skill.yaml",
    "sha256": "d1467599deb13369b60c04f0f0e38ee4ce36e11b4e96df90b7f409300d451d3f"
  },
  "steps": [
    {
      "id": "gc_overview",
      "name": "GC 概览",
      "query_id": "art_module/gc_overview",
      "result_dependencies": [],
      "save_as": "gc_overview",
      "type": "atomic"
    },
    {
      "id": "gc_events",
      "name": "GC 事件列表",
      "query_id": "art_module/gc_events",
      "result_dependencies": [],
      "save_as": "gc_events",
      "type": "atomic"
    },
    {
      "id": "gc_during_main_thread",
      "name": "主线程 GC",
      "query_id": "art_module/gc_during_main_thread",
      "result_dependencies": [],
      "save_as": "main_thread_gc",
      "type": "atomic"
    },
    {
      "id": "jit_events",
      "name": "JIT 编译事件",
      "query_id": "art_module/jit_events",
      "result_dependencies": [],
      "save_as": "jit_events",
      "type": "atomic"
    },
    {
      "id": "art_diagnosis",
      "inputs": [
        "gc_overview",
        "gc_events",
        "main_thread_gc",
        "jit_events"
      ],
      "name": "ART 诊断",
      "rules": [
        {
          "condition": "main_thread_gc.data.length > 0",
          "confidence": "high",
          "diagnosis": "主线程发生 ${main_thread_gc.data.length} 次 GC，可能导致卡顿",
          "evidence_fields": [
            "main_thread_gc.data.length",
            "main_thread_gc.data[0]?.dur_ms"
          ],
          "suggestions": [
            "减少临时对象分配",
            "使用对象池复用对象"
          ]
        },
        {
          "condition": "gc_overview.data[0]?.total_gc_ms > 100",
          "confidence": "high",
          "diagnosis": "GC 总耗时过长 (${gc_overview.data[0]?.total_gc_ms}ms)，内存压力大",
          "evidence_fields": [
            "gc_overview.data[0].total_gc_ms",
            "gc_overview.data[0].gc_count"
          ],
          "suggestions": [
            "检查是否有内存泄漏",
            "优化数据结构减少内存使用"
          ]
        },
        {
          "condition": "gc_events.data[0]?.dur_ms > 10",
          "confidence": "medium",
          "diagnosis": "存在长 GC 暂停 (${gc_events.data[0]?.dur_ms}ms)",
          "evidence_fields": [
            "gc_events.data[0].dur_ms",
            "gc_events.data[0].gc_type"
          ],
          "suggestions": [
            "增加堆大小",
            "避免在关键路径分配大对象"
          ]
        },
        {
          "condition": "jit_events.data[0]?.total_ms > 50",
          "confidence": "low",
          "diagnosis": "JIT 编译耗时较长 (${jit_events.data[0]?.total_ms}ms)",
          "evidence_fields": [
            "jit_events.data[0].total_ms"
          ],
          "suggestions": [
            "考虑 AOT 编译优化",
            "检查是否有热点方法未被编译"
          ]
        }
      ],
      "type": "diagnostic"
    }
  ],
  "type": "composite",
  "version": "1.0",
  "workflow": "memory"
}
