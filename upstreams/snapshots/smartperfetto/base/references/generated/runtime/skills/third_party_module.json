{
  "android": {
    "adapters": [
      {
        "id": "kernel_tracepoints",
        "selection": "available events, trace config/setup errors, schema, then rows"
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "%${package}%",
      "RenderThread",
      "main"
    ]
  },
  "id": "third_party_module",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "Target package name",
      "name": "package",
      "required": true,
      "type": "string"
    },
    {
      "description": "Analysis start timestamp",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "Analysis end timestamp",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.slices"
    ],
    "required_tables": []
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "68b113e0355716255af357e8396cd71c71e11d97",
    "path": "backend/skills/modules/app/third_party_module.skill.yaml",
    "sha256": "dacb92b3b21e6a6eb465c54481840390078de91ffe280ccb2ee14d978360ae96"
  },
  "steps": [
    {
      "id": "thread_overview",
      "name": "线程概览",
      "query_id": "third_party_module/thread_overview",
      "result_dependencies": [],
      "save_as": "thread_overview",
      "type": "atomic"
    },
    {
      "id": "main_thread_state",
      "name": "主线程状态分析",
      "query_id": "third_party_module/main_thread_state",
      "result_dependencies": [],
      "save_as": "main_thread_state",
      "type": "atomic"
    },
    {
      "id": "long_main_thread_slices",
      "name": "主线程耗时操作",
      "query_id": "third_party_module/long_main_thread_slices",
      "result_dependencies": [],
      "save_as": "long_slices",
      "type": "atomic"
    },
    {
      "id": "render_thread_analysis",
      "name": "RenderThread 分析",
      "query_id": "third_party_module/render_thread_analysis",
      "result_dependencies": [],
      "save_as": "render_thread_state",
      "type": "atomic"
    },
    {
      "id": "app_diagnosis",
      "inputs": [
        "thread_overview",
        "main_thread_state",
        "long_slices",
        "render_thread_state"
      ],
      "name": "应用诊断",
      "rules": [
        {
          "condition": "main_thread_state.data.find(s => s.state === 'Running')?.pct > 80",
          "confidence": "high",
          "diagnosis": "主线程 CPU 占用过高 (${main_thread_state.data.find(s => s.state === 'Running')?.pct}%)，可能导致 UI 响应慢",
          "evidence_fields": [
            "main_thread_state.data[0].pct",
            "main_thread_state.data[0].dur_ms"
          ],
          "suggestions": [
            "将耗时操作移至后台线程",
            "使用协程或线程池"
          ]
        },
        {
          "condition": "main_thread_state.data.find(s => s.state === 'R')?.pct > 10",
          "confidence": "high",
          "diagnosis": "主线程 Runnable 等待过长 (${main_thread_state.data.find(s => s.state === 'R')?.pct}%)，存在 CPU 竞争",
          "evidence_fields": [
            "main_thread_state.data.find(s => s.state === 'R')?.pct"
          ],
          "suggestions": [
            "减少后台线程数量",
            "检查是否有后台进程占用 CPU"
          ]
        },
        {
          "condition": "long_slices.data[0]?.dur_ms > 16",
          "confidence": "high",
          "diagnosis": "发现耗时主线程任务: ${long_slices.data[0]?.task_name} (${long_slices.data[0]?.dur_ms}ms)",
          "evidence_fields": [
            "long_slices.data[0].task_name",
            "long_slices.data[0].dur_ms"
          ],
          "suggestions": [
            "优化该任务或移至后台",
            "检查是否有同步 IO 或 Binder 调用"
          ]
        },
        {
          "condition": "thread_overview.data.length > 30",
          "confidence": "medium",
          "diagnosis": "应用线程数过多 (${thread_overview.data.length} 个活跃线程)",
          "evidence_fields": [
            "thread_overview.data.length"
          ],
          "suggestions": [
            "合并相似功能线程",
            "使用线程池管理"
          ]
        }
      ],
      "type": "diagnostic"
    }
  ],
  "type": "composite",
  "version": "1.0",
  "workflow": "frameworks-games"
}
