{
  "android": {
    "adapters": [
      {
        "id": "official_frame_timeline_or_legacy",
        "selection": "actual rows first; legacy Choreographer/DrawFrame fallback",
        "source": "perfetto stdlib android/frames/timeline.sql",
        "version_hint": {
          "frame_timeline_min_api": 31
        }
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "${package}*",
      "*MajorGC*",
      "*MinorGC*",
      "*V8.GC*",
      "*V8.GCCompactor*",
      "*V8.GCScavenger*",
      "*v8.compile*",
      "*v8.gc*",
      "*v8.run*"
    ]
  },
  "id": "webview_v8_analysis",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "目标进程名（支持 GLOB）",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "分析起始时间戳(ns)",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳(ns)",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.frames.timeline"
    ],
    "required_tables": [
      "slice"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
