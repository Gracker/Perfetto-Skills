  "id": "power_module",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "Target package name",
      "name": "package",
      "required": false,
      "type": "string"
    }
  ],
  "prerequisites": {
    "modules": [],
    "required_tables": [
      "counter",
      "counter_track"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "eb4ef81e660fc397c8cabe90ab0b499899931909",
    "path": "backend/skills/modules/hardware/power_module.skill.yaml",
    "sha256": "c78783057846e5a5481c15de86a5cfb018687fc79c03c89f11364a34bf005634"
  },
  "steps": [
    {
      "id": "wakelock_overview",
      "name": "Wakelock 概览",
      "on_empty": "未检测到 Wakelock 事件",
      "query_id": "power_module/wakelock_overview",
      "result_dependencies": [],
      "save_as": "wakelock_overview",
      "type": "atomic"
    },
    {
      "id": "long_wakelocks",
      "name": "长时间 Wakelock",
      "query_id": "power_module/long_wakelocks",
      "result_dependencies": [],
      "save_as": "long_wakelocks",
      "type": "atomic"
    },
    {
      "id": "cpu_idle_states",
      "name": "CPU 空闲状态",
      "optional": true,
      "query_id": "power_module/cpu_idle_states",
      "result_dependencies": [],
      "save_as": "cpu_idle_states",
      "type": "atomic"
    },
    {
      "id": "suspend_resume",
      "name": "休眠/唤醒事件",
      "query_id": "power_module/suspend_resume",
      "result_dependencies": [],
      "save_as": "suspend_resume",
      "type": "atomic"
    },
    {
      "id": "power_counters",
      "name": "电源计数器",
      "query_id": "power_module/power_counters",
      "result_dependencies": [],
      "save_as": "power_counters",
      "type": "atomic"
    },
    {
      "id": "power_mode_events",
      "name": "电源模式变化",
      "query_id": "power_module/power_mode_events",
      "result_dependencies": [],
      "save_as": "power_mode_events",
      "type": "atomic"
    },
    {
      "id": "wakeup_sources",
      "name": "唤醒源",
      "query_id": "power_module/wakeup_sources",
      "result_dependencies": [],
      "save_as": "wakeup_sources",
      "type": "atomic"
    },
    {
      "id": "power_diagnosis",
      "inputs": [
        "wakelock_overview",
        "long_wakelocks",
        "cpu_idle_states",
        "suspend_resume",
        "wakeup_sources"
      ],
      "name": "电源诊断",
      "rules": [
        {
          "condition": "long_wakelocks.data.length > 0",
          "confidence": "high",
          "diagnosis": "检测到 ${long_wakelocks.data.length} 个长时间持有的 Wakelock，最长 ${long_wakelocks.data[0]?.dur_ms}ms",
          "evidence_fields": [
            "long_wakelocks.data.length",
            "long_wakelocks.data[0]?.wakelock_name",
            "long_wakelocks.data[0]?.dur_ms"
          ],
          "suggestions": [
            "检查 Wakelock 是否必要",
            "确保在完成任务后释放 Wakelock",
            "考虑使用 WorkManager 替代"
          ]
        },
        {
          "condition": "wakelock_overview.data[0]?.total_ms > 10000",
          "confidence": "high",
          "diagnosis": "Wakelock 总持有时间 ${wakelock_overview.data[0]?.total_ms}ms，电量消耗较高",
          "evidence_fields": [
            "wakelock_overview.data[0]?.wakelock_event",
            "wakelock_overview.data[0]?.total_ms"
          ],
          "suggestions": [
            "优化 Wakelock 使用策略",
            "减少不必要的唤醒"
          ]
        },
        {
          "condition": "wakeup_sources.data[0]?.wakeup_count > 20",
          "confidence": "medium",
          "diagnosis": "唤醒次数过多: ${wakeup_sources.data[0]?.wakeup_source} 唤醒了 ${wakeup_sources.data[0]?.wakeup_count} 次",
          "evidence_fields": [
            "wakeup_sources.data[0]?.wakeup_source",
            "wakeup_sources.data[0]?.wakeup_count"
          ],
          "suggestions": [
            "合并定时任务减少唤醒",
            "使用 AlarmManager.setInexactRepeating()"
          ]
        },
        {
          "condition": "suspend_resume.data.length < 2",
          "confidence": "medium",
          "diagnosis": "设备未进入深度休眠，电量消耗增加",
          "evidence_fields": [
            "suspend_resume.data.length"
          ],
          "suggestions": [
            "检查是否有前台服务阻止休眠",
            "检查 Wakelock 使用情况"
          ]
        },
        {
          "condition": "cpu_idle_states.data[0]?.avg_value < 50",
          "confidence": "medium",
          "diagnosis": "CPU 空闲状态使用不充分",
          "evidence_fields": [
            "cpu_idle_states.data[0]?.idle_state",
            "cpu_idle_states.data[0]?.avg_value"
          ],
          "suggestions": [
            "检查后台任务是否过多",
            "优化定时器触发频率"
          ]
        }
      ],
      "type": "diagnostic"
    }
  ],
  "type": "composite",
  "version": "1.0",
  "workflow": "power-thermal"
}
