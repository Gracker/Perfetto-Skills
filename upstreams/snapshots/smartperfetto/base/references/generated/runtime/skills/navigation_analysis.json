{
  "android": {
    "adapters": [],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "${package}*",
      "${target_process.data[0].process_name}",
      "*ActivityTransition*",
      "*Binder*",
      "*Choreographer#doFrame*",
      "*Fragment*onCreate*",
      "*Fragment*onResume*",
      "*FragmentTransaction*",
      "*GC*",
      "*IO*",
      "*LayoutInflater*",
      "*SQL*",
      "*SharedElement*",
      "*SharedPreferences*",
      "*Transition*",
      "*activityResume*",
      "*activityStart*",
      "*binder*",
      "*collector*",
      "*commit*Fragment*",
      "*database*",
      "*file*",
      "*getSharedPreferences*",
      "*http*",
      "*inflate*",
      "*network*",
      "*okhttp*",
      "*performCreate*",
      "*performCreate*Fragment*",
      "*performDestroy*",
      "*performPause*",
      "*performResume*",
      "*performStart*",
      "*performStop*",
      "*read*",
      "*setContentView*",
      "*sqlite*",
      "*windowAnimation*",
      "*write*"
    ]
  },
  "id": "navigation_analysis",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "应用包名（可选）",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "分析起始时间戳（纳秒，可选）",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳（纳秒，可选）",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "default": 400,
      "description": "慢跳转判定阈值（ms）",
      "name": "slow_navigation_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 200,
      "description": "跳转评级-优秀阈值（ms）",
      "name": "nav_rating_good_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 700,
      "description": "跳转评级-严重阈值（ms）",
      "name": "nav_rating_severe_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 100,
      "description": "慢生命周期事件阈值（ms）",
      "name": "slow_lifecycle_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 5,
      "description": "阻塞操作最小显示阈值（ms）",
      "name": "blocking_op_min_dur_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 100,
      "description": "布局膨胀严重阈值（ms）",
      "name": "inflate_critical_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 16,
      "description": "Binder 阻塞判定阈值（ms）",
      "name": "binder_blocking_ms",
      "required": false,
      "type": "number"
    },
    {
      "default": 200,
      "description": "onCreate 过慢阈值（ms）",
      "name": "oncreate_slow_ms",
      "required": false,
      "type": "number"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.binder"
    ],
    "required_tables": []
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "cda248e2324a554220e15f8ce5ede39f2f53468d",
    "path": "backend/skills/composite/navigation_analysis.skill.yaml",
    "sha256": "1ebfd2d987dc15689b41fd76a43570d53d80c2054b688b131b355b37c3585b99"
  },
  "steps": [
    {
      "id": "check_lifecycle_data",
      "name": "检查生命周期数据",
      "query_id": "navigation_analysis/check_lifecycle_data",
      "result_dependencies": [],
      "save_as": "lifecycle_check",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available'",
      "id": "get_process",
      "name": "选择目标进程",
      "query_id": "navigation_analysis/get_process",
      "result_dependencies": [],
      "save_as": "target_process",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available' && target_process.data.length > 0",
      "id": "navigation_overview",
      "name": "跳转概览",
      "query_id": "navigation_analysis/navigation_overview",
      "result_dependencies": [
        "target_process"
      ],
      "save_as": "nav_overview",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available' && target_process.data.length > 0",
      "id": "lifecycle_phase_breakdown",
      "name": "生命周期阶段耗时",
      "query_id": "navigation_analysis/lifecycle_phase_breakdown",
      "result_dependencies": [
        "target_process"
      ],
      "save_as": "lifecycle_phases",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available' && target_process.data.length > 0",
      "id": "lifecycle_event_detail",
      "name": "生命周期事件详情",
      "query_id": "navigation_analysis/lifecycle_event_detail",
      "result_dependencies": [
        "target_process"
      ],
      "save_as": "lifecycle_detail",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available' && target_process.data.length > 0",
      "id": "navigation_blocking_ops",
      "name": "跳转期间主线程阻塞",
      "query_id": "navigation_analysis/navigation_blocking_ops",
      "result_dependencies": [
        "target_process"
      ],
      "save_as": "blocking_ops",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available' && target_process.data.length > 0",
      "id": "layout_inflation",
      "name": "布局膨胀分析",
      "query_id": "navigation_analysis/layout_inflation",
      "result_dependencies": [
        "target_process"
      ],
      "save_as": "layout_inflation",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available' && target_process.data.length > 0",
      "id": "fragment_transactions",
      "name": "Fragment 事务分析",
      "optional": true,
      "query_id": "navigation_analysis/fragment_transactions",
      "result_dependencies": [
        "target_process"
      ],
      "save_as": "fragment_txns",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available' && target_process.data.length > 0",
      "id": "transition_animations",
      "name": "转场动画分析",
      "optional": true,
      "query_id": "navigation_analysis/transition_animations",
      "result_dependencies": [
        "target_process"
      ],
      "save_as": "transition_anims",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available' && target_process.data.length > 0",
      "id": "navigation_binder_calls",
      "name": "跳转期间 Binder 调用",
      "optional": true,
      "query_id": "navigation_analysis/navigation_binder_calls",
      "result_dependencies": [
        "target_process"
      ],
      "save_as": "nav_binder",
      "type": "atomic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'available' && target_process.data.length > 0",
      "id": "first_frame_render",
      "name": "首帧渲染分析",
      "query_id": "navigation_analysis/first_frame_render",
      "result_dependencies": [
        "target_process"
      ],
      "save_as": "first_frames",
      "type": "atomic"
    },
    {
      "id": "navigation_diagnosis",
      "inputs": [
        "nav_overview",
        "lifecycle_phases",
        "blocking_ops",
        "layout_inflation",
        "nav_binder"
      ],
      "name": "跳转诊断",
      "rules": [
        {
          "condition": "(layout_inflation?.data?.length || 0) > 0 && layout_inflation.data[0]?.dur_ms > ${inflate_critical_ms|100}",
          "confidence": "high",
          "diagnosis": "SLOW_INFLATE: 布局膨胀严重 (${layout_inflation.data[0].dur_ms}ms)，是跳转耗时主因",
          "severity": "critical",
          "suggestions": [
            "减少布局嵌套层级，使用 ConstraintLayout",
            "使用 ViewStub 延迟加载非首屏布局",
            "考虑使用异步布局膨胀 (AsyncLayoutInflater)"
          ]
        },
        {
          "condition": "(nav_binder?.data?.length || 0) > 0 && nav_binder.data[0]?.max_dur_ms > ${binder_blocking_ms|16} && nav_binder.data[0]?.main_thread_calls > 0",
          "confidence": "high",
          "diagnosis": "SLOW_BINDER: 跳转期间主线程 Binder 阻塞 (最大 ${nav_binder.data[0].max_dur_ms}ms)",
          "severity": "warning",
          "suggestions": [
            "将 Binder 调用移到后台线程",
            "使用异步 Binder 接口",
            "缓存服务调用结果"
          ]
        },
        {
          "condition": "(blocking_ops?.data?.length || 0) > 0 && blocking_ops.data.find(b => b.block_type === 'file_io' || b.block_type === 'database' || b.block_type === 'shared_prefs')?.dur_ms > ${binder_blocking_ms|16}",
          "confidence": "high",
          "diagnosis": "SLOW_IO: 跳转期间存在 IO 阻塞 (${blocking_ops.data.find(b => b.block_type === 'file_io' || b.block_type === 'database' || b.block_type === 'shared_prefs')?.dur_ms}ms)",
          "severity": "warning",
          "suggestions": [
            "将 IO 操作移到后台线程",
            "使用 ViewModel 预加载数据",
            "使用内存缓存减少磁盘读取"
          ]
        },
        {
          "condition": "(lifecycle_phases?.data?.length || 0) > 0 && (lifecycle_phases.data.find(p => p.phase === 'onCreate')?.max_dur_ms || 0) > ${oncreate_slow_ms|200}",
          "confidence": "medium",
          "diagnosis": "SLOW_ONCREATE: Activity onCreate 耗时过长 (${lifecycle_phases.data.find(p => p.phase === 'onCreate')?.max_dur_ms}ms)",
          "severity": "warning",
          "suggestions": [
            "延迟初始化非必要组件",
            "将数据加载移到后台线程",
            "使用 Jetpack App Startup 优化初始化顺序"
          ]
        },
        {
          "condition": "(nav_overview?.data?.[0]?.avg_nav_dur_ms || 0) <= ${slow_navigation_ms|400}",
          "confidence": "high",
          "diagnosis": "NAVIGATION_NORMAL: 跳转性能正常 (平均 ${nav_overview?.data?.[0]?.avg_nav_dur_ms}ms)",
          "severity": "info",
          "suggestions": [
            "跳转性能良好，无需优化"
          ]
        }
      ],
      "type": "diagnostic"
    },
    {
      "condition": "lifecycle_check.data[0]?.status === 'unavailable'",
      "id": "no_data_fallback",
      "name": "无数据提示",
      "query_id": "navigation_analysis/no_data_fallback",
      "result_dependencies": [],
      "type": "atomic"
    }
  ],
  "type": "composite",
  "version": "3.0",
  "workflow": "interaction"
}
