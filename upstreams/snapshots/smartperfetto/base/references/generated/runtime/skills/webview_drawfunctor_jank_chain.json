  },
  "id": "webview_drawfunctor_jank_chain",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "目标进程名（支持 GLOB）",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "目标进程名别名；当 package 为空时使用",
      "name": "process_name",
      "required": false,
      "type": "string"
    },
    {
      "description": "分析起始时间戳(ns)",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳(ns)",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.frames.timeline",
      "slices.with_context"
    ],
    "required_tables": [
      "actual_frame_timeline_slice",
      "slice",
      "thread_track",
      "thread",
      "process"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
