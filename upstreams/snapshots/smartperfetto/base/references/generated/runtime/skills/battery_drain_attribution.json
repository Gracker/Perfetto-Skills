{
  "android": {
    "adapters": [
      {
        "id": "kernel_tracepoints",
        "selection": "available events, trace config/setup errors, schema, then rows"
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": []
  },
  "id": "battery_drain_attribution",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "description": "目标进程名（可选）",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "目标进程名别名；当 package 为空时使用",
      "name": "process_name",
      "required": false,
      "type": "string"
    },
    {
      "description": "分析起始时间戳(ns)",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳(ns)",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.battery",
      "android.battery.doze",
      "android.kernel_wakelocks",
      "android.wakeups",
      "android.screen_state",
      "android.job_scheduler",
      "android.network_packets",
      "linux.cpu.idle"
    ],
    "required_tables": []
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "40048058243cbb91ef11082a06ba1e4d0f7d3c5a",
    "path": "backend/skills/composite/battery_drain_attribution.skill.yaml",
    "sha256": "d35668e7c2d4eb757ad7b58857fef582f741e61dd8617d0941fbd2072ed61819"
  },
  "steps": [
    {
      "id": "battery_drain_rate",
      "name": "掉电速率摘要",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "start_ts": "${start_ts}"
      },
      "save_as": "battery_drain_rate",
      "skill": "battery_drain_rate_summary",
      "type": "skill"
    },
    {
      "id": "battery_charge",
      "name": "电池采样",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "start_ts": "${start_ts}"
      },
      "save_as": "battery_charge",
      "skill": "battery_charge_timeline",
      "type": "skill"
    },
    {
      "id": "doze_state",
      "name": "Doze 状态",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "start_ts": "${start_ts}"
      },
      "save_as": "doze_state",
      "skill": "battery_doze_state_timeline",
      "type": "skill"
    },
    {
      "id": "wakelock_summary",
      "name": "Wakelock 汇总",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "start_ts": "${start_ts}"
      },
      "save_as": "wakelock_summary",
      "skill": "android_kernel_wakelock_summary",
      "type": "skill"
    },
    {
      "id": "wakeup_frequency",
      "name": "唤醒频率摘要",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "start_ts": "${start_ts}"
      },
      "save_as": "wakeup_frequency",
      "skill": "wakeup_frequency_summary",
      "type": "skill"
    },
    {
      "id": "screen_off_cpu",
      "name": "熄屏后台 CPU",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}"
      },
      "save_as": "screen_off_cpu",
      "skill": "screen_off_background_cpu_attribution",
      "type": "skill"
    },
    {
      "id": "suspend_wakeup",
      "name": "Suspend/Wakeup 链路",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "start_ts": "${start_ts}"
