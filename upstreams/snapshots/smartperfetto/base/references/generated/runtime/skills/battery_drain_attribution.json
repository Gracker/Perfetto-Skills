      "save_as": "suspend_wakeup",
      "skill": "suspend_wakeup_analysis",
      "type": "skill"
    },
    {
      "id": "job_scheduler",
      "name": "JobScheduler 事件",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package|${process_name|}}",
        "start_ts": "${start_ts}"
      },
      "save_as": "job_scheduler",
      "skill": "android_job_scheduler_events",
      "type": "skill"
    },
    {
      "id": "network_activity",
      "name": "网络活动",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "package": "${package}",
        "start_ts": "${start_ts}"
      },
      "save_as": "network_activity",
      "skill": "network_analysis",
      "type": "skill"
    },
    {
      "id": "modem_network",
      "name": "Modem / 蜂窝网络相关性",
      "optional": true,
      "params": {
        "end_ts": "${end_ts}",
        "start_ts": "${start_ts}"
      },
      "save_as": "modem_network",
      "skill": "modem_network_correlation_summary",
      "type": "skill"
    }
  ],
  "type": "composite",
  "version": "1.0",
  "workflow": "power-thermal"
}
