      "name": "Launcher 主线程概览",
      "on_empty": "未找到 Launcher 进程或主线程数据",
      "query_id": "launcher_module/launcher_main_thread",
      "result_dependencies": [],
      "save_as": "launcher_main_thread",
      "type": "atomic"
    },
    {
      "id": "launcher_frames",
      "name": "Launcher 帧渲染",
      "query_id": "launcher_module/launcher_frames",
