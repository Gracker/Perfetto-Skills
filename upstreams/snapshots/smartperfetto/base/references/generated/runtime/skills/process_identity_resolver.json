{
  "android": {
    "adapters": [
      {
        "id": "official_frame_timeline_or_legacy",
        "selection": "actual rows first; legacy Choreographer/DrawFrame fallback",
        "source": "perfetto stdlib android/frames/timeline.sql",
        "version_hint": {
          "frame_timeline_min_api": 31
        }
      },
      {
        "id": "android_input_source",
        "selection": "data-source descriptor, build type, config, then rows",
        "version_hint": {
          "proto_input_min_api_hint": 34
        }
      }
    ],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "/apex/*",
      "/odm/bin/*",
      "/system/bin/*",
      "/system_ext/bin/*",
      "/vendor/bin/*",
      "Cr*Main",
      "[0-9]*.raster",
      "[0-9]*.ui",
      "battery_stats.top",
      "com.android.inputmethod*",
      "com.android.launcher*",
      "com.android.systemui*",
      "com.google.android.apps.nexuslauncher*",
      "com.google.android.inputmethod*",
      "com.huawei.android.launcher*",
      "com.miui.home*",
      "com.oppo.launcher*",
      "com.sec.android.app.launcher*",
      "com.vivo.launcher*"
    ]
  },
  "id": "process_identity_resolver",
  "identity": {
    "policy": "exempt",
    "scope": "process"
  },
  "inputs": [
    {
      "description": "用户期望的 Android 包名或进程名前缀",
      "name": "package",
      "required": false,
      "type": "string"
    },
    {
      "description": "目标进程名别名；当 package 为空时使用",
      "name": "process_name",
      "required": false,
      "type": "string"
    },
    {
      "description": "可选线程名线索，例如 main、RenderThread、1.ui、CrRendererMain",
      "name": "thread_name",
      "required": false,
      "type": "string"
    },
    {
      "description": "已知 trace 内唯一进程 ID；优先级最高",
      "name": "upid",
      "required": false,
      "type": "integer"
    },
    {
      "description": "已知 OS 进程 ID；仅作为辅助线索，PID 可能复用",
      "name": "pid",
      "required": false,
      "type": "integer"
    },
    {
      "description": "分析起始时间戳(ns)，默认 trace_start()",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "分析结束时间戳(ns)，默认 trace_end()",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "default": 20,
      "description": "最多返回候选进程数",
      "name": "max_rows",
      "required": false,
      "type": "integer"
    }
  ],
  "prerequisites": {
    "modules": [
      "android.process_metadata",
      "android.frames.timeline",
      "android.oom_adjuster",
      "android.battery_stats"
    ],
    "required_tables": []
  },
  "query_id": "process_identity_resolver/root",
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "053b09e27d56c7727cbe5d7447e32a50b41c5bee",
    "path": "backend/skills/atomic/process_identity_resolver.skill.yaml",
