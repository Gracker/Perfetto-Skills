{
  "android": {
    "adapters": [],
    "selection_order": [
      "device_capability",
      "trace_config_and_setup_errors",
      "engine_module_and_schema",
      "target_range_row_coverage",
      "api_hint"
    ],
    "signal_patterns": [
      "*Choreographer#doFrame*",
      "*DrawFrame*",
      "*doFrame*"
    ]
  },
  "id": "scroll_session_analysis",
  "identity": {
    "policy": "none"
  },
  "inputs": [
    {
      "name": "session_id",
      "required": true,
      "type": "number"
    },
    {
      "name": "start_ts",
      "required": true,
      "type": "timestamp"
    },
    {
      "name": "end_ts",
      "required": true,
      "type": "timestamp"
    },
    {
      "name": "duration_ms",
      "required": false,
      "type": "number"
    },
    {
      "name": "frame_count",
      "required": false,
      "type": "number"
    },
    {
      "name": "touch_start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "name": "touch_end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "name": "touch_duration_ms",
      "required": false,
      "type": "number"
    },
    {
      "name": "fling_start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "name": "fling_end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "name": "fling_duration_ms",
      "required": false,
      "type": "number"
    },
    {
      "name": "has_fling",
      "required": false,
      "type": "number"
    }
  ],
  "prerequisites": {
    "modules": [],
    "required_tables": [
      "android_input_event"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
  "schema_version": 1,
  "source": {
    "commit": "cda248e2324a554220e15f8ce5ede39f2f53468d",
    "path": "backend/skills/composite/scroll_session_analysis.skill.yaml",
    "sha256": "fd8dbf2ef3390842217b4b5877ff5a8dd65c44f0edbaaa4d59ba036370f53517"
  },
  "steps": [
    {
      "id": "full_session_stats",
      "name": "完整区间统计",
      "query_id": "scroll_session_analysis/full_session_stats",
      "result_dependencies": [],
      "save_as": "full_stats",
      "type": "atomic"
    },
    {
      "condition": "touch_start_ts != null",
      "id": "touch_phase_stats",
      "name": "按压滑动阶段统计",
      "query_id": "scroll_session_analysis/touch_phase_stats",
      "result_dependencies": [],
      "save_as": "touch_stats",
      "type": "atomic"
    },
    {
      "condition": "has_fling == 1",
      "id": "fling_phase_stats",
      "name": "Fling 阶段统计",
      "query_id": "scroll_session_analysis/fling_phase_stats",
      "result_dependencies": [],
      "save_as": "fling_stats",
      "type": "atomic"
    },
    {
      "id": "identify_janky_frames",
      "name": "识别掉帧",
      "query_id": "scroll_session_analysis/identify_janky_frames",
      "result_dependencies": [],
      "save_as": "janky_frames",
      "type": "atomic"
    },
    {
      "filter": "jank_level == 'severe' OR jank_level == 'bad'",
      "id": "analyze_janky_frames",
      "item_params": {
        "dur_ms": "dur_ms",
        "end_ts": "end_ts_str",
        "start_ts": "ts_str"
      },
      "item_skill": "jank_frame_detail",
      "max_items": 10,
      "name": "掉帧原因分析",
      "save_as": "frame_diagnostics",
      "source": "janky_frames",
      "type": "iterator"
    },
    {
      "id": "session_diagnosis",
      "inputs": [
        "full_stats",
        "touch_stats",
        "fling_stats",
        "janky_frames"
      ],
      "name": "区间诊断",
      "rules": [
        {
          "condition": "full_stats.data[0].jank_rate > 15",
          "confidence": "high",
          "diagnosis": "滑动掉帧率过高 (${full_stats.data[0].jank_rate}%)",
          "severity": "critical",
          "suggestions": [
            "检查主线程耗时操作",
            "优化列表项布局复杂度",
            "使用 RecyclerView 的 setHasFixedSize 和 setItemViewCacheSize"
          ]
        },
        {
          "condition": "full_stats.data[0].jank_rate > 5",
          "confidence": "medium",
          "diagnosis": "滑动存在掉帧 (${full_stats.data[0].jank_rate}%)",
          "severity": "warning",
          "suggestions": [
            "检查 onBindViewHolder 耗时",
            "避免在滑动时加载图片"
          ]
        },
        {
          "condition": "full_stats.data[0].max_frame_ms > 100",
          "confidence": "high",
          "diagnosis": "存在严重卡顿帧 (最大 ${full_stats.data[0].max_frame_ms}ms)",
          "severity": "critical",
          "suggestions": [
            "检查是否有 IO 操作在主线程",
            "检查是否有同步 Binder 调用",
            "分析可能的 ANR 风险"
          ]
        },
        {
          "condition": "touch_stats.data[0].jank_rate > ${fling_stats.data[0].jank_rate} * 2",
          "confidence": "medium",
          "diagnosis": "按压滑动阶段掉帧更严重",
          "severity": "warning",
          "suggestions": [
            "检查 dispatchTouchEvent 链路",
            "优化手势响应代码"
          ]
        },
        {
          "condition": "fling_stats.data[0].jank_rate > ${touch_stats.data[0].jank_rate} * 2",
          "confidence": "medium",
          "diagnosis": "Fling 阶段掉帧更严重",
          "severity": "warning",
          "suggestions": [
            "检查 Fling 动画计算",
            "优化滑动曲线计算逻辑"
          ]
        },
        {
          "condition": "full_stats.data[0].estimated_fps < 50",
          "confidence": "medium",
          "diagnosis": "帧率偏低 (${full_stats.data[0].estimated_fps} fps)",
          "severity": "warning",
          "suggestions": [
            "优化 onDraw 方法",
            "减少过度绘制",
            "使用硬件加速"
          ]
        }
      ],
      "type": "diagnostic"
    }
  ],
  "type": "composite",
  "version": "1.0",
  "workflow": "scrolling"
}
