  },
  "steps": [
    {
      "id": "data_check",
      "name": "GPU compute data availability",
      "query_id": "gpu_compute_kernel_analysis/data_check",
      "result_dependencies": [],
      "save_as": "data_check",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.compute_rows > 0",
      "id": "kernel_summary",
      "name": "GPU compute kernel timing",
      "query_id": "gpu_compute_kernel_analysis/kernel_summary",
      "result_dependencies": [],
      "save_as": "kernel_summary",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.launch_arg_rows > 0",
      "id": "launch_configuration",
      "name": "Producer-provided compute launch configuration",
      "optional": true,
      "query_id": "gpu_compute_kernel_analysis/launch_configuration",
      "result_dependencies": [],
      "save_as": "launch_configuration",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.compute_rows === 0",
      "id": "no_compute_contract",
      "name": "No GPU compute kernels",
      "optional": true,
      "query_id": "gpu_compute_kernel_analysis/no_compute_contract",
      "result_dependencies": [],
      "save_as": "no_compute_contract",
      "type": "atomic"
    },
    {
      "condition": "data_check.data[0]?.compute_rows > 0 && data_check.data[0]?.launch_arg_rows === 0",
      "id": "missing_launch_args_contract",
      "name": "Compute launch arguments unavailable",
      "optional": true,
      "query_id": "gpu_compute_kernel_analysis/missing_launch_args_contract",
      "result_dependencies": [],
      "save_as": "missing_launch_args_contract",
      "type": "atomic"
    }
  ],
  "type": "composite",
  "version": "1.0",
  "workflow": "gpu-rendering"
}
