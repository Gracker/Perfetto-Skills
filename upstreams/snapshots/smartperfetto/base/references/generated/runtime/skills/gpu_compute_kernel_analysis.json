  },
  "inputs": [
    {
      "description": "Optional inclusive start timestamp in ns",
      "name": "start_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "Optional exclusive end timestamp in ns",
      "name": "end_ts",
      "required": false,
      "type": "timestamp"
    },
    {
      "description": "Optional host-unique GPU id",
      "name": "ugpu",
      "required": false,
      "type": "integer"
    },
    {
      "default": 50,
      "description": "Maximum kernel or launch rows, clamped to 200",
      "name": "max_rows",
      "required": false,
      "type": "integer"
    }
  ],
  "prerequisites": {
    "modules": [
      "prelude.after_eof.events"
    ],
    "required_tables": [
      "gpu_slice",
      "gpu_track"
    ]
  },
  "query_id": null,
  "runtime_status": "executable",
